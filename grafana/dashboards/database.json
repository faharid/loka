{
  "uid": "observe-database",
  "title": "Database Dashboard",
  "tags": ["observe", "database"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "DB query duration P95 (ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_ms_bucket[5m])) by (le, operation))",
          "legendFormat": "{{operation}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Connection pool active",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "db_connection_pool_active",
          "legendFormat": "active"
        },
        {
          "expr": "db_connection_pool_idle",
          "legendFormat": "idle"
        }
      ]
    },
    {
      "id": 3,
      "title": "Slow queries (>100ms)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(db_slow_queries_total[5m])) by (operation)",
          "legendFormat": "{{operation}}"
        }
      ]
    }
  ]
}
