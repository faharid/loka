# =============================================================================
# observe stack — environment reference
# Copy values as needed; Compose uses inline env in docker-compose.yml
# =============================================================================

# --- Alertmanager (edit alertmanager/config.yml, not this file) ---
# Add a Slack receiver with a full https:// URL, e.g.:
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00/B00/XXXXXXXX

# --- Loki retention ---
# Edit loki/loki-config.yml → limits_config.retention_period (default: 72h)

# --- NestJS example (local: npm run start:dev) ---
LOKI_URL=http://localhost:3100
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=nestjs-app
PORT=3001
# LOG_LEVEL=info
# ENABLE_LOKI=false   # disable Loki transport only

# --- NestJS in Docker (set in docker-compose.yml profile examples) ---
# LOKI_URL=http://loki:3100
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# --- React example (copy to frontend-integration/react-example/.env) ---
# VITE_API_URL=http://localhost:3001
# VITE_PUSHGATEWAY_URL=http://localhost:9091
# VITE_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# VITE_OTEL_SERVICE_NAME=web-app
